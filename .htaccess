RewriteEngine On
RewriteBase /otelex-server/api

# Never expose internal PHP handlers, configuration or database exports directly.
RewriteRule ^(?:includes|routes)/ - [F,L,NC]
<FilesMatch "(^\.|\.(?:env|ini|log|sql|bak)$|^composer\.(?:json|lock)$)">
    Require all denied
</FilesMatch>

# All public API traffic must pass through the secured router.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

ErrorDocument 404 /otelex-server/api/index.php
